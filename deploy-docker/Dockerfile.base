# Ubuntu 22.04 + Node.js 20 + Claude Code + Codex CLI + Gemini CLI + Git
# Optional: code-server (Web VS Code)

FROM ubuntu:22.04

# Build argument for code-server installation
ARG INSTALL_CODE_SERVER=false

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    sudo \
    ca-certificates \
    gnupg \
    wget \
    vim \
    htop \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20.x LTS
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Verify Node.js installation
RUN node --version && npm --version

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Install OpenAI Codex CLI globally
RUN npm install -g @openai/codex

# Install Google Gemini CLI globally
RUN npm install -g @google/gemini-cli

# Install code-server (Web VS Code) - only if INSTALL_CODE_SERVER=true
RUN if [ "$INSTALL_CODE_SERVER" = "true" ]; then \
        echo "Installing code-server..." && \
        curl -fsSL https://code-server.dev/install.sh | sh; \
    else \
        echo "Skipping code-server installation"; \
    fi

# Create non-root user 'developer' with sudo privileges and default password
# 创建 developer 用户，设置默认密码 123456，并赋予 sudo 权限
RUN useradd -m -s /bin/bash -G sudo developer \
    && echo "developer:123456" | chpasswd \
    && echo "developer ALL=(ALL:ALL) ALL" >> /etc/sudoers

# Create workspace, app, and shared config directories
RUN mkdir -p /workspace /app \
    /home/developer/.claude /home/developer/.codex /home/developer/.agents \
    /home/developer/.npm /home/developer/.cache /home/developer/.npm-global /home/developer/.local/share/pnpm/store \
    /root/.local/share/pnpm \
    && chown -R developer:developer /workspace /app /home/developer/.claude /home/developer/.codex /home/developer/.agents /home/developer/.npm /home/developer/.cache /home/developer/.npm-global /home/developer/.local \
    && ln -sfn /home/developer/.claude /root/.claude \
    && ln -sfn /home/developer/.codex /root/.codex \
    && ln -sfn /home/developer/.agents /root/.agents \
    && ln -sfn /home/developer/.npm /root/.npm \
    && ln -sfn /home/developer/.cache /root/.cache \
    && ln -sfn /home/developer/.npm-global /root/.npm-global \
    && ln -sfn /home/developer/.local/share/pnpm/store /root/.local/share/pnpm/store

# Set Git configuration for developer user
RUN su - developer -c "git config --global init.defaultBranch main" \
    && su - developer -c "git config --global user.email 'developer@container.local'" \
    && su - developer -c "git config --global user.name 'Developer'"

# Set working directory
WORKDIR /workspace

# Switch to non-root user
USER developer

# Configure npm global prefix for developer user (avoids EACCES on npm install -g)
# 配置 npm 全局安装路径到用户目录（避免权限问题）
RUN mkdir -p /home/developer/.npm-global \
    && npm config set prefix '/home/developer/.npm-global'

# Set environment variables
ENV HOME=/home/developer
ENV CC_CONFIG_HOME=/home/developer
ENV NPM_CONFIG_PREFIX=/home/developer/.npm-global
ENV PATH="/home/developer/.npm-global/bin:/home/developer/.local/bin:${PATH}"

# Default command
CMD ["/bin/bash"]
